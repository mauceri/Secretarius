# External data root (kept outside ~/Secretarius)
MILVUS_DATA_ROOT=/home/mauceric/milvus-data

# Images (single source of truth)
MILVUS_IMAGE=milvusdb/milvus:v2.2.13
ETCD_IMAGE=quay.io/coreos/etcd:v3.5.5
MINIO_IMAGE=minio/minio:RELEASE.2023-03-20T20-16-18Z

# Ports
MILVUS_GRPC_PORT=19530
MILVUS_HEALTH_PORT=9091
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# MinIO credentials (for local dev only)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
