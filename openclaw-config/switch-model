#!/usr/bin/env python3
"""Bascule le modèle principal de Tiron et redémarre le gateway."""
import json
import os
import subprocess
import sys

CONFIG = os.path.expanduser("~/.openclaw/openclaw.json")
BAK = os.path.expanduser("~/.openclaw/openclaw.json.bak")

ALIASES = {
    "euria":      "euria/mistralai/Mistral-Small-4-119B-2603",
    "deepseek":   "deepseek/deepseek-chat",
    "ollm":       "ollm/near/DeepSeek-V3.1",
    "gemma4":     "ollama/gemma4:latest",
    "glm4":       "ollama/glm4:latest",
    "granite3b":  "ollama/granite4:3b",
    "tiron-llm":  "openai/phi-4-mini-instruct",
}

def main():
    if len(sys.argv) != 2 or sys.argv[1] in ("-h", "--help"):
        print(f"Usage: switch-model <{'|'.join(ALIASES.keys())}>")
        sys.exit(0)

    alias = sys.argv[1].lower()
    if alias not in ALIASES:
        print(f"Alias inconnu : {alias}")
        print(f"Disponibles : {', '.join(ALIASES.keys())}")
        sys.exit(1)

    model_id = ALIASES[alias]

    with open(CONFIG) as f:
        config = json.load(f)

    current = config["agents"]["defaults"]["model"]["primary"]
    if current == model_id:
        print(f"Modèle déjà actif : {model_id}")
        sys.exit(0)

    config["agents"]["defaults"]["model"]["primary"] = model_id
    with open(CONFIG, "w") as f:
        json.dump(config, f, indent=2)

    # Sync .bak pour éviter l'anti-clobber au prochain démarrage
    try:
        import shutil
        shutil.copy2(CONFIG, BAK)
    except Exception:
        pass

    subprocess.run(["systemctl", "--user", "restart", "openclaw-gateway.service"], check=True)
    print(f"Modèle basculé : {current} → {model_id}")
    print("Gateway redémarré.")

if __name__ == "__main__":
    main()
