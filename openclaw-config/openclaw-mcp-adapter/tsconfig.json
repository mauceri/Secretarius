{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": ".",
    "rootDir": ".",
    "declaration": false,
    "strict": false,
    "noImplicitAny": false,
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["index.ts", "mcp-client.ts", "config.ts"],
  "exclude": ["node_modules"]
}
