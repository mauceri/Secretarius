#!/usr/bin/env bash
# scout-watcher — Surveille tasks/pending/ et soumet les tâches à l'agent scout
# Installé dans ~/.local/bin/scout-watcher par install.sh
set -euo pipefail

SCOUT_WORKSPACE="${HOME}/.openclaw/agents/scout/workspace"
PENDING="${SCOUT_WORKSPACE}/tasks/pending"
DONE="${SCOUT_WORKSPACE}/tasks/done"
RESULTS="${SCOUT_WORKSPACE}/results"

mkdir -p "$PENDING" "$DONE" "$RESULTS"

echo "[scout-watcher] Démarré — surveillance de ${PENDING}"

while true; do
  for task_file in "${PENDING}"/*.json; do
    [[ -f "$task_file" ]] || continue

    task_id="$(basename "$task_file" .json)"
    echo "[scout-watcher] Tâche détectée : ${task_id}"

    # Pré-fetch de l'URL si la tâche en contient une
    URL="$(python3 -c "
import sys, json
with open(sys.argv[1]) as f:
    d = json.load(f)
print(d.get('url_or_path', ''))
" "$task_file" 2>/dev/null || echo '')"

    if [[ -n "$URL" && "$URL" =~ ^https?:// ]]; then
      echo "[scout-watcher] Fetch : ${URL}"
      FETCHED_FILE="$(mktemp)"
      CURL_HTTP_CODE="$(curl -sL --max-time 30 --user-agent 'Scout/1.0' \
          -w '%{http_code}' -o "$FETCHED_FILE" "$URL" 2>/dev/null || echo '000')"
      FETCHED_SIZE="$(wc -c < "$FETCHED_FILE")"

      if [[ "$CURL_HTTP_CODE" =~ ^[23] && "$FETCHED_SIZE" -gt 0 ]]; then
        python3 - "$task_file" "$FETCHED_FILE" <<'PYEOF'
import sys, json, re, html as html_mod
task_file, content_file = sys.argv[1], sys.argv[2]
with open(task_file) as f:
    data = json.load(f)
with open(content_file, errors='replace') as f:
    raw = f.read()
# Nettoyage HTML si la page en contient
if '<' in raw and '>' in raw:
    raw = re.sub(r'<script[^>]*>.*?</script>', ' ', raw, flags=re.DOTALL|re.IGNORECASE)
    raw = re.sub(r'<style[^>]*>.*?</style>', ' ', raw, flags=re.DOTALL|re.IGNORECASE)
    raw = re.sub(r'<[^>]+>', ' ', raw)
    raw = html_mod.unescape(raw)
    raw = re.sub(r'\s+', ' ', raw).strip()
# Limite à 15000 caractères
content = raw[:15000]
data['fetched_content'] = content
with open(task_file, 'w') as f:
    json.dump(data, f, ensure_ascii=False, indent=2)
print(len(content))
PYEOF
        INJECTED="$?"
        echo "[scout-watcher] Contenu injecté : HTTP ${CURL_HTTP_CODE}, brut ${FETCHED_SIZE} octets"
      else
        echo "[scout-watcher] ERREUR fetch : HTTP ${CURL_HTTP_CODE}, ${FETCHED_SIZE} octets — tâche abandonnée" >&2
        python3 -c "
import json, datetime, sys
result = {
    'source': sys.argv[1],
    'retrieved_at': datetime.datetime.utcnow().isoformat() + 'Z',
    'error': 'fetch_failed',
    'http_code': sys.argv[2],
    'summary': 'Impossible de récupérer le contenu (HTTP ' + sys.argv[2] + ').',
    'raw_excerpt': '',
    'warnings': []
}
print(json.dumps(result, ensure_ascii=False, indent=2))
" "$URL" "$CURL_HTTP_CODE" > "${RESULTS}/${task_id}.json"
        rm -f "$FETCHED_FILE"
        mv "$task_file" "${DONE}/${task_id}.json"
        continue
      fi
      rm -f "$FETCHED_FILE"
    fi

    # Soumettre la tâche à l'agent scout via openclaw (mode embarqué)
    # Scout lit tasks/pending/<task_id>.json et écrit results/<task_id>.json via write
    RAW_OUTPUT="$("${OPENCLAW_BIN:-openclaw}" agent --agent scout --message "task_id: ${task_id}" --json 2>&1)" || {
      echo "[scout-watcher] ERREUR openclaw agent pour ${task_id} :" >&2
      echo "$RAW_OUTPUT" >&2
      mv "$task_file" "${DONE}/${task_id}.json"
      continue
    }

    if [[ -s "${RESULTS}/${task_id}.json" ]]; then
      echo "[scout-watcher] Résultat écrit : ${RESULTS}/${task_id}.json"
    else
      echo "[scout-watcher] AVERTISSEMENT : résultat absent ou vide pour ${task_id}" >&2
      echo "[scout-watcher] Sortie agent : ${RAW_OUTPUT}" >&2
    fi

    # Déplacer la tâche vers done/ dans tous les cas
    mv "$task_file" "${DONE}/${task_id}.json"
  done

  sleep 5
done
