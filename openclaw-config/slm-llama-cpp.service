[Unit]
Description=llama.cpp inference server (Phi-4-mini, cerveau SLM local de Tiron)
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/llama.cpp/build/bin
ExecStart=%h/llama.cpp/build/bin/llama-server \
    -m %h/Modèles/Phi-4-mini-instruct-Q6_K.gguf \
    -c 32768 \
    -ngl 32 \
    --host 0.0.0.0 \
    --port 8998 \
    --jinja
Restart=on-failure
RestartSec=5
Environment=HSA_OVERRIDE_GFX_VERSION=10.3.0

[Install]
WantedBy=default.target
