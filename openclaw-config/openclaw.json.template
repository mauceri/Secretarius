    "provider": "euria",
    "mode": "api_key"
   },
   "deepseek:default": {
    "provider": "deepseek",
    "mode": "api_key"
   }
  }
 },
 "models": {
  "mode": "merge",
  "providers": {
   "euria": {
    "baseUrl": "https://api.infomaniak.com/2/ai/${EURIA_PRODUCT_ID}/openai/v1",
