     {
      "id": "nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-FP8",
      "name": "Nemotron 3 Nano 30B-A3B (Euria)",
      "api": "openai-completions",
      "reasoning": false,
      "input": ["text"],
      "contextWindow": 131072,
