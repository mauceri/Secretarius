[Unit]
Description=Secretarius Prototype server
After=network-online.target secretarius_ollama.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/mauceric/Secretarius/Prototype
Environment=PATH=/home/mauceric/Secretarius/.venv/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/home/mauceric/Secretarius/.venv/bin/python /home/mauceric/Secretarius/Prototype/server_secretarius.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
