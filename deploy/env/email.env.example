# IMAP settings
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=bot@example.com
EMAIL_IMAP_PASSWORD=replace_me
EMAIL_IMAP_MAILBOX=INBOX

# SMTP settings
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=bot@example.com
EMAIL_SMTP_PASSWORD=replace_me
EMAIL_SENDER=bot@example.com

# Optional: allow-list senders (comma-separated)
# EMAIL_ALLOWED_SENDERS=alice@example.com,bob@example.com
EMAIL_ALLOWED_SENDERS=

# Polling interval in seconds
EMAIL_POLL_INTERVAL_S=10

# Optional Qwen runtime tuning
SECRETARIUS_QWEN_MODEL=Qwen3-0.6B
SECRETARIUS_QWEN_MODEL_SERVER=http://127.0.0.1:8000/v1
SECRETARIUS_QWEN_API_KEY=EMPTY
SECRETARIUS_QWEN_CODE_INTERPRETER=false
SECRETARIUS_QWEN_THOUGHT_IN_CONTENT=true

# Optional MCP entrypoint overrides
# SECRETARIUS_MCP_PYTHON=/home/mauceric/Secretarius/.venv/bin/python
# SECRETARIUS_MCP_ENTRYPOINT=/home/mauceric/Secretarius/run_secretarius_mcp.py

