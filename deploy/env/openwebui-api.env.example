# Host/port for the OpenAI-compatible facade used by Open WebUI.
HOST=0.0.0.0
PORT=8000

# Agent internal model backend (Open WebUI does not need to know this).
SECRETARIUS_QWEN_MODEL=qwen3:0.6b
SECRETARIUS_QWEN_MODEL_SERVER=http://127.0.0.1:11434/v1
SECRETARIUS_QWEN_API_KEY=EMPTY
SECRETARIUS_QWEN_CODE_INTERPRETER=false
SECRETARIUS_QWEN_THOUGHT_IN_CONTENT=true

# Optional MCP entrypoint overrides
# SECRETARIUS_MCP_PYTHON=/home/mauceric/Secretarius/.venv/bin/python
# SECRETARIUS_MCP_ENTRYPOINT=/home/mauceric/Secretarius/run_secretarius_mcp.py

# Milvus for semantic graph tool
SECRETARIUS_MILVUS_URI=http://127.0.0.1:19530
SECRETARIUS_MILVUS_COLLECTION=secretarius_semantic_graph_384
SECRETARIUS_MILVUS_METRIC=COSINE

