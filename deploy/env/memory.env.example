# Memory API bind
MEMORY_HOST=0.0.0.0
MEMORY_PORT=8011

# Shared runtime model backend
SECRETARIUS_QWEN_MODEL=qwen3:0.6b
SECRETARIUS_QWEN_MODEL_SERVER=http://sanroque:8989/v1
SECRETARIUS_QWEN_API_KEY=EMPTY

# Extraction backend
SECRETARIUS_LLAMA_CPP_URL=http://sanroque:8989/v1/chat/completions
SECRETARIUS_LLAMA_CPP_MODEL=local-llama-cpp

# Milvus backend
SECRETARIUS_MILVUS_URI=http://127.0.0.1:19530
SECRETARIUS_MILVUS_COLLECTION=secretarius_semantic_graph_384
SECRETARIUS_MILVUS_METRIC=COSINE

# Memory defaults
SECRETARIUS_MEMORY_TOP_K=5
SECRETARIUS_LOG_LEVEL=INFO
