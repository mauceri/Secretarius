: [], "document": {"schema": "secretarius.document.v0.1", "doc_id": "doc:c50dffef196395e46dd8622dae37b748ac72fa807a69645b83e10339d52a245e", "type": "note", "source": {"urls": [], "source_id": "src:071f8f36a3934d39935dbc15dfc7f4419f1c8515d48912141ef1851e27d1fc6d"}, "content": {"text": "L'écriture est née de la nécessité de fixer la pensée et de transmettre l'information au-delà de l'oralité. Les premières traces apparaissent en Mésopotamie avec l'écriture cunéiforme, suivie des hiéroglyphes égyptiens. Chaque civilisation a développé son propre système, des idéogrammes chinois à l'alphabet phénicien, ancêtre de la plupart des écritures modernes. Cette invention a fondamentalement transformé les sociétés, permettant l'administration, la littérature et la préservation du savoir à travers les siècles.", "hash": "sha256:b02a251b296a0361b408c481354ade62379d0a92f6c62ce460845fd07d17b62d"}, "user_fields": {"type_note": "fugace", "title": "L'évolution des systèmes d'écriture", "document_date": "15-03-2023", "keywords": ["#écriture", "#histoire", "#civilisation"], "updated_at": "2026-03-14T16:43:27Z", "created_at": "2026-03-14T16:43:19Z"}, "derived": {"chunks": [{"chunk_id": "chunk:02f156e3eab86c2ba3e6ab70b567447119c87f9c6500280ef50f005c16c74288", "start": 0, "end": 521, "text_ref": null}], "expressions": [{"expression": "écriture", "span": [2, 10], "weight": null, "norm": "écriture", "embedding_ref": "emb:14dbf2140003b3f9514a659dcfea18b7a8d252a0f73f1e06db724bf87aa0bbd2"}, {"expression": "Mésopotamie", "span": [145, 156], "weight": null, "norm": "mésopotamie", "embedding_ref": "emb:2161e2cb7e9e0bd12679781125917bc1873f48cbc720ba6ceed40bde80745a5d"}, {"expression": "écriture cunéiforme", "span": [164, 183], "weight": null, "norm": "écriture cunéiforme", "embedding_ref": "emb:da96b1f5f39adf551773eed24f7636dc2fa2787977e0f730db56bccb2d9a9442"}, {"expression": "hiéroglyphes égyptiens", "span": [196, 218], "weight": null, "norm": "hiéroglyphes égyptiens", "embedding_ref": "emb:c9a27a0e76526f9e12cc5929a98a2e948f391980919e316c0e6a94fb3382d574"}, {"expression": "idéogrammes chinois", "span": [276, 295], "weight": null, "norm": "idéogrammes chinois", "embedding_ref": "emb:09f8d4f312d050a8084b3973d7d99b0407344f32b3102cc19cf91b94378d5dfd"}, {"expression": "alphabet phénicien", "span": [300, 318], "weight": null, "norm": "alphabet phénicien", "embedding_ref": "emb:4b68e41be67918155cec3c7139bd1b88e3ad1f88b17deca64bd9fa9027b214d9"}, {"expression": "écritures modernes", "span": [346, 364], "weight": null, "norm": "écritures modernes", "embedding_ref": "emb:2f3c4fb0a87bb7f6009abd1ce1dd748ee78ace1cbcc0053ab86fc31195f32559"}, {"expression": "administration", "span": [439, 453], "weight": null, "norm": "administration", "embedding_ref": "emb:28f3ac334055784782b32060aa6aa3d1fcd6c8942f41fea07630f29c8eb0352e"}, {"expression": "littérature", "span": [458, 469], "weight": null, "norm": "littérature", "embedding_ref": "emb:3f74484df1a2eb2f9ac82a971c3f782cfa9a1a134042d9c9d7696ec8767b5575"}, {"expression": "préservation du savoir", "span": [476, 498], "weight": null, "norm": "préservation du savoir", "embedding_ref": "emb:d2fc6f73ab8168ff2090a2426cee06a5650fe7c28c0bb5f733f91aa165e9d7d8"}]}, "indexing": {"pipeline_version": "v0.1", "state": "done", "errors": [], "source": "document_pipeline:index_text", "source_expression_idx": 1, "source_expression": "Mésopotamie"}}}], "warning": null}
