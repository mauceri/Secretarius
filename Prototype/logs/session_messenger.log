], "weight": null, "norm": "laboratoires", "embedding_ref": "emb:02701c3fea6505cfc1ac3a3128bd16e86316484fd8ff4cb4ab969494fefe511e"}, {"expression": "entreprises technologiques", "span": [859, 885], "weight": null, "norm": "entreprises technologiques", "embedding_ref": "emb:4683069e30340d247c1c283bdcc685e6fc82584ade8cf90c3b7a9fca7e220421"}, {"expression": "secteurs", "span": [946, 954], "weight": null, "norm": "secteurs", "embedding_ref": "emb:8eec2494c87e100bc79e491cf7750719a7f0c961413dd62b9b88e1bf764ecdbc"}]}, "indexing": {"pipeline_version": "v0.1", "state": "done", "errors": [], "source": "document_pipeline:index_text", "source_expression_idx": 7, "source_expression": "mécanique quantique"}}}], "warning": null}
