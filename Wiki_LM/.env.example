# Chemin vers les données du wiki (vault Obsidian — pages .md synchronisées)
WIKI_PATH=/home/mauceric/Documents/Arbath/Wiki_LM

# Chemin vers raw/ (hors vault — non synchronisé par Obsidian, local uniquement)
# Défaut : ~/Secretarius/Wiki_LM/raw/
# WIKI_RAW_PATH=/home/mauceric/Secretarius/Wiki_LM/raw

# Backend LLM : claude | ollama | openai
WIKI_LLM_BACKEND=openai

# --- Backend openai (DeepSeek ou autre API OpenAI-compatible) ---
OPENAI_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=sk-...   # prioritaire sur OPENAI_API_KEY
OPENAI_MODEL=deepseek-chat

# --- Backend ollama (modèle local) ---
# WIKI_LLM_BACKEND=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=granite4:3b

# --- Backend claude (Anthropic API) ---
# WIKI_LLM_BACKEND=claude
# ANTHROPIC_API_KEY=sk-ant-...
