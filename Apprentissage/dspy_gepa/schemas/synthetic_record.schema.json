{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "synthetic_record.schema.json",
  "title": "SyntheticTrainingRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_id",
    "instruction",
    "context",
    "response",
    "metadata"
  ],
  "properties": {
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "instruction": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "string"
    },
    "response": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "language",
        "difficulty",
        "synthetic",
        "tags"
      ],
      "properties": {
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "const": "fr"
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "basic",
            "intermediate",
            "advanced"
          ]
        },
        "synthetic": {
          "type": "boolean",
          "const": true
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
